# Backend runtime
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000
AUTO_MIGRATE_ON_STARTUP=true

# Supabase (MVP target storage/auth stack)
SUPABASE_URL=https://jwurvkzuctcjbsxglazj.supabase.co
SUPABASE_ANON_KEY=sb_publishable_z5XrGtft9094ZiI9qRj4ig_e59qrvTy
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
SUPABASE_JWT_SECRET=
# DB connection (single source for API + migrations)
# Use a direct Postgres connection (port 5432). Supabase "Transaction" pooler
# on 6543 is PgBouncer transaction mode and breaks psycopg/SQLAlchemy (DuplicatePreparedStatement).
# Dashboard: Project Settings → Database → copy the URI for direct connection, or
# postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:replace-with-db-password@db.jwurvkzuctcjbsxglazj.supabase.co:5432/postgres

# AI provider
ANTHROPIC_API_KEY=

# Optional investigation behavior toggles
AUTO_APPROVE_HIGH_SEVERITY=false
DEFAULT_MODEL_PROVIDER=anthropic

# Legacy AWS/S3 variables from pre-MVP architecture (keep commented unless needed):
# AWS_PROFILE=your-profile-name
# TSP_S3_BUCKET=trade-surveillance-bucket
# TSP_RAW_PREFIX=raw/
# TSP_FEATURES_KEY=features/features.parquet
