# API
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
AUTO_MIGRATE_ON_STARTUP=true

# Postgres — use Supabase "Session Pooler" URI (port 5432, host aws-…pooler.supabase.com).
# Why: the direct host db.<ref>.supabase.co is IPv6-only on Free/Pro and breaks Docker.
# Do NOT use the Transaction Pooler (port 6543) — it disables prepared statements.
# Replace the driver prefix with postgresql+psycopg:// when copying from the dashboard.
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:replace-with-db-password@aws-<n>-<region>.pooler.supabase.com:5432/postgres

# Agents / investigate_trade (read directly from os.environ, not Settings)
ANTHROPIC_API_KEY=

