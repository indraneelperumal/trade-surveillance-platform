# AWS — batch jobs and agents use a named profile via boto3.Session.
AWS_PROFILE=your-profile-name

# Anthropic — required for investigate_trade / compliance memo node.
ANTHROPIC_API_KEY=

# Optional overrides (defaults match the demo bucket layout).
# TSP_S3_BUCKET=trade-surveillance-bucket
# TSP_RAW_PREFIX=raw/
# TSP_FEATURES_KEY=features/features.parquet
# TSP_ANOMALIES_KEY=processed/anomalies.parquet
# TSP_MODEL_KEY=model/isolation_forest.pkl
# TSP_MEDIANS_KEY=model/medians.json
# TSP_MEMOS_PREFIX=memos
